# Realtime backend to use: "local" or "huggingface".
# Defaults to "local" when unset.
# BACKEND_PROVIDER="local"

# Hugging Face connection mode: "deployed" or "local".
# Deployed mode uses the built-in Hugging Face server.
# Defaults to "deployed" when unset.
# HF_REALTIME_CONNECTION_MODE="deployed"

# Direct Hugging Face realtime endpoint for local/LAN backends.
# Accepts either the base URL (`ws://127.0.0.1:8765/v1`) or the full realtime URL
# (`ws://127.0.0.1:8765/v1/realtime`). Used when HF_REALTIME_CONNECTION_MODE=local.
# HF_REALTIME_WS_URL="ws://127.0.0.1:8765/v1/realtime"

# Direct wired media override. Useful for Mac mini <-> Reachy Mini Ethernet.
# REACHY_MEDIA_HOST=10.42.0.2

# Local Mac backend. Requires llama.cpp for chat/router/vision, MLX Whisper, and Piper.
# Recommended setup:
#   brew install llama.cpp
#   llama-server -hf ggml-org/gemma-3-1b-it-GGUF:Q4_K_M -np 2 -c 4096 -fa on --host 127.0.0.1 --port 8080 --no-webui
#   llama-server -hf Qwen/Qwen3-0.6B-GGUF:Q8_0 -np 1 -c 1024 -fa on --host 127.0.0.1 --port 8082 --no-webui
#   llama-server -hf ggml-org/SmolVLM2-500M-Video-Instruct-GGUF:Q8_0 -np 1 -c 2048 -fa on --host 127.0.0.1 --port 8081 --no-webui
#   uv run python -m piper.download_voices --download-dir ./cache/piper-voices en_US-lessac-medium
# LOCAL_CHAT_BASE_URL=http://127.0.0.1:8080/v1
# LOCAL_CHAT_MODEL=ggml-org/gemma-3-1b-it-GGUF
# LOCAL_CHAT_NUM_PREDICT=96
# LOCAL_ROUTER_BASE_URL=http://127.0.0.1:8082/v1
# LOCAL_ROUTER_MODEL=Qwen/Qwen3-0.6B-GGUF
# LOCAL_ROUTER_NUM_CTX=448
# LOCAL_ROUTER_NUM_PREDICT=18
# LOCAL_VAD_SILENCE_SECONDS=0.45
# LOCAL_STT_PROVIDER=mlx-whisper
# LOCAL_STT_MODEL=mlx-community/whisper-small-mlx
# LOCAL_TTS_PROVIDER=piper
# PIPER_VOICE=./cache/piper-voices/en_US-lessac-medium.onnx

# Fast local camera-question vision. The default local path targets a separate
# llama.cpp/OpenAI-compatible vision server instead of chat-model vision.
# LOCAL_VISION_BASE_URL=http://127.0.0.1:8081/v1
# LOCAL_VISION_SERVER_MODEL=ggml-org/SmolVLM2-500M-Video-Instruct-GGUF
# LOCAL_VISION_NUM_PREDICT=48
# LOCAL_VISION_MAX_IMAGE_SIDE=512

# Transformers local vision model (only used with --local-vision CLI flag)
# LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct

# Cache for local VLM (only used with --local-vision CLI flag)
HF_HOME=./cache

# Hugging Face token for accessing datasets/models
HF_TOKEN=

# Optional repo-backed profile selector. Use a folder name from src/reachy_mini_conversation_app/profiles/.
# If unset, the app uses the default profile unless startup settings were saved from the UI.
# REACHY_MINI_CUSTOM_PROFILE=default
